{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "ricoberger-incidentio-datasource",
        "uid": "incidentio"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "hideFrom": {
              "viz": false
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Title"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": true,
                    "title": "incident.io",
                    "url": "https://app.incident.io/company/on-call/alerts?view=${__data.fields[\"ID\"].text}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ID"
            },
            "properties": [
              {
                "id": "custom.hideFrom.viz",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "firing": {
                        "color": "red",
                        "index": 0
                      },
                      "resolved": {
                        "color": "green",
                        "index": 1
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Priority"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "Critical": {
                        "color": "red",
                        "index": 3
                      },
                      "Error": {
                        "color": "red",
                        "index": 2
                      },
                      "Info": {
                        "color": "blue",
                        "index": 0
                      },
                      "Warning": {
                        "color": "orange",
                        "index": 1
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 24,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "pluginVersion": "12.3.0",
      "targets": [
        {
          "datasource": {
            "type": "ricoberger-incidentio-datasource",
            "uid": "incidentio"
          },
          "filters": [
            {
              "attribute": "status",
              "operator": "one_of",
              "value": "${status:csv}"
            }
          ],
          "limit": 100,
          "queryType": "alerts",
          "refId": "A"
        }
      ],
      "title": "Alerts",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Alert Owner Criteria": true,
              "Dagster Code Location": true,
              "Description": true,
              "Escalation Path": true,
              "Labels": true,
              "Resolved At": true,
              "Updated At": true
            },
            "includeByName": {},
            "indexByName": {},
            "renameByName": {
              "Created At": ""
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "preload": false,
  "schemaVersion": 42,
  "tags": [],
  "templating": {
    "list": [
      {
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "definition": "",
        "description": "",
        "includeAll": true,
        "label": "Status",
        "multi": true,
        "name": "status",
        "options": [],
        "query": {
          "attribute": "status",
          "queryType": "attributevalues",
          "type": "alerts"
        },
        "refresh": 1,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Alerts",
  "uid": "alerts",
  "version": 3
}

